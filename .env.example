# Server
PORT=3000
NODE_ENV=production

# Frontend Origin (for CORS)
CLIENT_ORIGIN=https://g.tap.t-lyfe.com.ng

# Database (same as PHP)
DB_HOST=localhost
DB_USER=tlyfecom_golden_tap
DB_PASSWORD=dnRkDFrWhCN9GDUwFSMN
DB_NAME=tlyfecom_golden_tap
DB_SSL=false

# JWT Secret (must match PHP config — min 32 chars, random)
JWT_SECRET=gt_jwt_32char_secret_key_production_change!

# Internal API key (PHP <-> Node communication)
INTERNAL_API_KEY=gt_internal_key_change_this_in_prod

# PHP Backend URL (for Node to call PHP endpoints)
PHP_API_BASE=https://g.tap.t-lyfe.com.ng/backend
